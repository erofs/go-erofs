diff --git a/lib/tar.c b/lib/tar.c
--- a/lib/tar.c
+++ b/lib/tar.c
@@ -12,6 +12,7 @@
 #ifdef _WIN32
 #include <fcntl.h>
 #include <io.h>
+#include <windows.h>
 #endif
 #include "erofs/print.h"
